<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My Space</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500&family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            background: #0f0f14;
            color: #f5f5f5;
            line-height: 1.6;
        }

        nav {
            display: flex;
            justify-content: space-between;
            padding: 20px 10%;
            background: rgba(255,255,255,0.03);
            backdrop-filter: blur(10px);
            position: sticky;
            top: 0;
        }

        nav h2 {
            font-family: 'Playfair Display', serif;
            font-weight: 500;
        }

        nav ul {
            display: flex;
            gap: 20px;
            list-style: none;
        }

        nav ul li a {
            text-decoration: none;
            color: #f5f5f5;
            font-weight: 400;
            transition: 0.3s;
        }

        nav ul li a:hover {
            color: #8ab4f8;
        }

        .hero {
            height: 90vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            padding: 0 20px;
        }

        .hero h1 {
            font-size: 3rem;
            font-family: 'Playfair Display', serif;
        }

        .hero p {
            margin-top: 15px;
            font-size: 1.2rem;
            color: #bdbdbd;
        }

        section {
            padding: 80px 10%;
        }

        section h2 {
            font-size: 2rem;
            margin-bottom: 20px;
            border-bottom: 2px solid #8ab4f8;
            display: inline-block;
            padding-bottom: 5px;
        }

        .card {
            background: #1a1a22;
            padding: 20px;
            margin-top: 20px;
            border-radius: 12px;
            transition: 0.3s;
        }

        .card:hover {
            transform: translateY(-5px);
            background: #22222c;
        }

        footer {
            text-align: center;
            padding: 30px;
            color: #888;
        }

        @media(max-width: 768px){
            .hero h1 {
                font-size: 2.2rem;
            }
        }
    </style>
</head>

<body>

    <!-- NAVIGATION -->
    <nav>
        <!-- EDIT HERE -->
        <h2>Xarles Reve R. Buencamino</h2>
        <ul>
            <li><a href="#about">About</a></li>
            <li><a href="#skills">Skills</a></li>
            <li><a href="#projects">Projects</a></li>
            <li><a href="#contact">Contact</a></li>
        </ul>
    </nav>

    <!-- HERO SECTION -->
    <div class="hero">
        <!-- EDIT HERE -->
        <h1>Hello, I'm Xarles Reve R. Buencamino</h1>
        <p>Aspiring Engineer | Choreographer | Dancer</p>
    </div>

    <!-- ABOUT -->
    <section id="about">
        <h2>About Me</h2>
        <div class="card">
            <!-- EDIT HERE -->
            <p>
                I’m a 16-year-old STEM student from Lopez, Quezon. I’m also a dedicated dancesport athlete. I dream of becoming both an engineer and a choreographer—combining logic and creativity in everything I do.
            </p>
        </div>
    </section>

    <!-- SKILLS -->
    <section id="skills">
        <h2>Skills</h2>
        <div class="card">
            <!-- EDIT HERE -->
            <p>Mathematician</p>
            <p>Dancer</p>
            <p>Creative Thinking</p>
        </div>
    </section>


    </section>

    <!-- CONTACT -->
    <section id="contact">
        <h2>Contact</h2>
        <div class="card">
            <!-- EDIT HERE -->
            <p>Email:reyesrevebuencamino@gmail.com </p>
            <p>Phone: 0905-523-0293</p>
        </div>
    </section>

    <footer>
      G11-STEM FORTITUDE
    </footer>

</body>
</html>
